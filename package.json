{
  "name": "grafana-dashboard-sync",
  "displayName": "Grafana Dashboard Sync",
  "description": "Manage Grafana dashboards from VS Code with pull, render, deploy, backup, and datasource mapping workflows.",
  "version": "0.8.10",
  "publisher": "vaslit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaslit/grafana-dashboard-sync.git"
  },
  "homepage": "https://github.com/vaslit/grafana-dashboard-sync#readme",
  "bugs": {
    "url": "https://github.com/vaslit/grafana-dashboard-sync/issues"
  },
  "keywords": [
    "grafana",
    "dashboards",
    "observability",
    "monitoring",
    "devops",
    "infrastructure",
    "visualization"
  ],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.grafana-dashboard-workspace.json",
    "workspaceContains:**/.grafana-dashboard-workspace.json",
    "onView:grafanaDashboards.dashboards",
    "onView:grafanaDashboards.instances",
    "onView:grafanaDashboards.backups",
    "onView:grafanaDashboards.details",
    "onCommand:grafanaDashboards.refresh",
    "onCommand:grafanaDashboards.initializeProject",
    "onCommand:grafanaDashboards.selectActiveInstance",
    "onCommand:grafanaDashboards.selectDevTarget",
    "onCommand:grafanaDashboards.createDeploymentTarget",
    "onCommand:grafanaDashboards.removeDeploymentTarget",
    "onCommand:grafanaDashboards.pickPlacementFolder",
    "onCommand:grafanaDashboards.setInstanceToken",
    "onCommand:grafanaDashboards.clearInstanceToken",
    "onCommand:grafanaDashboards.checkoutRevisionFromTree",
    "onCommand:grafanaDashboards.setTargetRevisionFromTree",
    "onCommand:grafanaDashboards.deployRevisionToActiveTargetFromTree",
    "onCommand:grafanaDashboards.deleteRevisionFromTree",
    "onCommand:grafanaDashboards.openDashboardInBrowser",
    "onCommand:grafanaDashboards.createBackup",
    "onCommand:grafanaDashboards.createAllDashboardsBackup",
    "onCommand:grafanaDashboards.restoreBackup",
    "onCommand:grafanaDashboards.deployAllDashboards",
    "onCommand:grafanaDashboards.renderDashboard",
    "onCommand:grafanaDashboards.renderTarget",
    "onCommand:grafanaDashboards.renderInstance",
    "onCommand:grafanaDashboards.renderAllInstances",
    "onCommand:grafanaDashboards.openRenderFolder",
    "onCommand:grafanaDashboards.removeInstance"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grafanaDashboards",
          "title": "Grafana",
          "icon": "media/grafana.svg"
        }
      ]
    },
    "views": {
      "grafanaDashboards": [
        {
          "id": "grafanaDashboards.instances",
          "name": "Instances"
        },
        {
          "id": "grafanaDashboards.dashboards",
          "name": "Dashboards"
        },
        {
          "id": "grafanaDashboards.backups",
          "name": "Backups"
        },
        {
          "id": "grafanaDashboards.details",
          "name": "Details",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "grafanaDashboards.initializeProject",
        "title": "Initialize Grafana Dashboard Project"
      },
      {
        "command": "grafanaDashboards.refresh",
        "title": "Refresh"
      },
      {
        "command": "grafanaDashboards.selectActiveInstance",
        "title": "Select Active Deployment Target"
      },
      {
        "command": "grafanaDashboards.selectDevTarget",
        "title": "Select Dev Target"
      },
      {
        "command": "grafanaDashboards.setInstanceToken",
        "title": "Set Instance Token"
      },
      {
        "command": "grafanaDashboards.clearInstanceToken",
        "title": "Clear Instance Token"
      },
      {
        "command": "grafanaDashboards.checkoutRevisionFromTree",
        "title": "Checkout Revision"
      },
      {
        "command": "grafanaDashboards.setTargetRevisionFromTree",
        "title": "Set Revision On Active Target"
      },
      {
        "command": "grafanaDashboards.deployRevisionToActiveTargetFromTree",
        "title": "Deploy Revision To Active Target"
      },
      {
        "command": "grafanaDashboards.deleteRevisionFromTree",
        "title": "Delete Revision"
      },
      {
        "command": "grafanaDashboards.createBackup",
        "title": "Create Backup"
      },
      {
        "command": "grafanaDashboards.createAllDashboardsBackup",
        "title": "Create Backup of All Dashboards"
      },
      {
        "command": "grafanaDashboards.restoreBackup",
        "title": "Restore Backup"
      },
      {
        "command": "grafanaDashboards.deployAllDashboards",
        "title": "Deploy All Dashboards"
      },
      {
        "command": "grafanaDashboards.renderDashboard",
        "title": "Render Dashboard"
      },
      {
        "command": "grafanaDashboards.renderTarget",
        "title": "Render Target"
      },
      {
        "command": "grafanaDashboards.renderInstance",
        "title": "Render Instance"
      },
      {
        "command": "grafanaDashboards.renderAllInstances",
        "title": "Render All Instances"
      },
      {
        "command": "grafanaDashboards.openRenderFolder",
        "title": "Open Render Folder"
      },
      {
        "command": "grafanaDashboards.openBackupFolder",
        "title": "Open Backup Folder"
      },
      {
        "command": "grafanaDashboards.deleteBackup",
        "title": "Delete Backup"
      },
      {
        "command": "grafanaDashboards.createManifestFromExample",
        "title": "Create Manifest From Example"
      },
      {
        "command": "grafanaDashboards.addDashboard",
        "title": "Add Dashboard"
      },
      {
        "command": "grafanaDashboards.pullDashboard",
        "title": "Pull Dashboard From Dev Target",
        "icon": {
          "light": "media/pull-light.svg",
          "dark": "media/pull-dark.svg"
        }
      },
      {
        "command": "grafanaDashboards.deployDashboard",
        "title": "Deploy Dashboard",
        "icon": {
          "light": "media/deploy-light.svg",
          "dark": "media/deploy-dark.svg"
        }
      },
      {
        "command": "grafanaDashboards.openDashboardJson",
        "title": "Open Dashboard JSON"
      },
      {
        "command": "grafanaDashboards.openDashboardInBrowser",
        "title": "Open Dashboard In Browser"
      },
      {
        "command": "grafanaDashboards.removeDashboard",
        "title": "Remove Dashboard"
      },
      {
        "command": "grafanaDashboards.createInstance",
        "title": "Create Instance"
      },
      {
        "command": "grafanaDashboards.createDeploymentTarget",
        "title": "Create Deployment Target"
      },
      {
        "command": "grafanaDashboards.removeDeploymentTarget",
        "title": "Remove Deployment Target"
      },
      {
        "command": "grafanaDashboards.pickPlacementFolder",
        "title": "Choose Placement Folder"
      },
      {
        "command": "grafanaDashboards.removeInstance",
        "title": "Remove Instance"
      },
      {
        "command": "grafanaDashboards.openOverrideFile",
        "title": "Open Override File"
      },
      {
        "command": "grafanaDashboards.generateOverride",
        "title": "Generate Override From Dashboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "grafanaDashboards.initializeProject",
          "when": "view == grafanaDashboards.dashboards",
          "group": "project@1"
        },
        {
          "command": "grafanaDashboards.refresh",
          "when": "view == grafanaDashboards.dashboards || view == grafanaDashboards.instances || view == grafanaDashboards.backups",
          "group": "general@1"
        },
        {
          "command": "grafanaDashboards.createManifestFromExample",
          "when": "view == grafanaDashboards.dashboards",
          "group": "project@2"
        },
        {
          "command": "grafanaDashboards.addDashboard",
          "when": "view == grafanaDashboards.dashboards",
          "group": "manage@1"
        },
        {
          "command": "grafanaDashboards.createAllDashboardsBackup",
          "when": "view == grafanaDashboards.dashboards",
          "group": "sync@1"
        },
        {
          "command": "grafanaDashboards.deployAllDashboards",
          "when": "view == grafanaDashboards.dashboards",
          "group": "sync@2"
        },
        {
          "command": "grafanaDashboards.createInstance",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@1"
        },
        {
          "command": "grafanaDashboards.createDeploymentTarget",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@2"
        },
        {
          "command": "grafanaDashboards.selectDevTarget",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@2.5"
        },
        {
          "command": "grafanaDashboards.renderAllInstances",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@3"
        },
        {
          "command": "grafanaDashboards.createAllDashboardsBackup",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@4"
        },
        {
          "command": "grafanaDashboards.deployAllDashboards",
          "when": "view == grafanaDashboards.instances",
          "group": "manage@5"
        }
      ],
      "view/item/context": [
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "inline@1"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "inline@2"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "inline@3"
        },
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.instances && (viewItem == grafanaInstance || viewItem == grafanaDeploymentTarget || viewItem == grafanaInstanceDashboard)",
          "group": "inline@1"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.instances && (viewItem == grafanaInstance || viewItem == grafanaDeploymentTarget || viewItem == grafanaInstanceDashboard)",
          "group": "inline@2"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.instances && (viewItem == grafanaInstance || viewItem == grafanaDeploymentTarget || viewItem == grafanaInstanceDashboard)",
          "group": "inline@3"
        },
        {
          "command": "grafanaDashboards.openDashboardJson",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.openDashboardInBrowser",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@0.5"
        },
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@1"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@2"
        },
        {
          "command": "grafanaDashboards.renderDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@3"
        },
        {
          "command": "grafanaDashboards.generateOverride",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@4"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@5"
        },
        {
          "command": "grafanaDashboards.removeDashboard",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboard",
          "group": "navigation@10"
        },
        {
          "command": "grafanaDashboards.checkoutRevisionFromTree",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboardRevision",
          "group": "navigation@1"
        },
        {
          "command": "grafanaDashboards.setTargetRevisionFromTree",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboardRevision",
          "group": "navigation@2"
        },
        {
          "command": "grafanaDashboards.deployRevisionToActiveTargetFromTree",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboardRevision",
          "group": "navigation@3"
        },
        {
          "command": "grafanaDashboards.deleteRevisionFromTree",
          "when": "view == grafanaDashboards.dashboards && viewItem == grafanaDashboardRevision",
          "group": "navigation@10"
        },
        {
          "command": "grafanaDashboards.selectDevTarget",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDevTargetSelector",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.createDeploymentTarget",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@4"
        },
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@5"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@6"
        },
        {
          "command": "grafanaDashboards.renderInstance",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@7"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@7.5"
        },
        {
          "command": "grafanaDashboards.setInstanceToken",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@7.75"
        },
        {
          "command": "grafanaDashboards.clearInstanceToken",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@8"
        },
        {
          "command": "grafanaDashboards.removeInstance",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstance",
          "group": "navigation@9"
        },
        {
          "command": "grafanaDashboards.openDashboardJson",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.openDashboardInBrowser",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation@0.5"
        },
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation@1"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation@2"
        },
        {
          "command": "grafanaDashboards.renderDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation@3"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaInstanceDashboard",
          "group": "navigation@4"
        },
        {
          "command": "grafanaDashboards.pullDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@8.5"
        },
        {
          "command": "grafanaDashboards.deployDashboard",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@9"
        },
        {
          "command": "grafanaDashboards.renderTarget",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@9.25"
        },
        {
          "command": "grafanaDashboards.createBackup",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@9.35"
        },
        {
          "command": "grafanaDashboards.openRenderFolder",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@9.5"
        },
        {
          "command": "grafanaDashboards.removeDeploymentTarget",
          "when": "view == grafanaDashboards.instances && viewItem == grafanaDeploymentTarget",
          "group": "navigation@11"
        },
        {
          "command": "grafanaDashboards.restoreBackup",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackup",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.restoreBackup",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackupInstance",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.restoreBackup",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackupTarget",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.restoreBackup",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackupDashboard",
          "group": "navigation"
        },
        {
          "command": "grafanaDashboards.openBackupFolder",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackup",
          "group": "navigation@1"
        },
        {
          "command": "grafanaDashboards.deleteBackup",
          "when": "view == grafanaDashboards.backups && viewItem == grafanaBackup",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && node --test ./out/test/*.test.js",
    "package": "vsce package",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.88.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.5"
  }
}
